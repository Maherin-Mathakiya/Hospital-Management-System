@model HMS.Models.DoctorDepartmentModel;
@using HMS.Models

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div class="h2 text-primary fw-bold mb-2 mb-md-0">Assign Doctor to Department</div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Hospital Management</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Doctor Department</a></li>
            <li class="breadcrumb-item active" aria-current="page">Assign</li>
        </ol>
    </nav>
</div>

<div class="card shadow-lg p-4">
    <div class="card-body">
        <h4 class="card-title mb-4 fw-bold text-secondary">Assignment Information</h4>
        <form method="post" asp-controller="DoctorDepartment" asp-action="DoctorDepartmentSave">
            @* Hidden field for the ID when editing an existing record *@
            <input type="hidden" asp-for="DoctorDepartmentID" />

            <div class="row g-4">
                @* User Name Field *@
                <div class="col-md-6">
                    <label asp-for="UserID" class="form-label fw-bold">User Name</label>
                    <select class="form-select" asp-for="UserID">
                        <option value="">-- Select User --</option>
                        @foreach (User_DropDownModel name in ViewBag.UserList)
                        {
                            <option value="@name.UserID">@name.UserName</option>
                        }
                    </select>
                    <span asp-validation-for="UserID" class="text-danger small mt-1 d-block"></span>
                </div>

                @* Doctor Name Field *@
                <div class="col-md-6">
                    <label asp-for="DoctorID" class="form-label fw-bold">Doctor Name</label>
                    <select class="form-select" asp-for="DoctorID">
                        <option value="">-- Select Doctor --</option>
                        @foreach (Doctor_DropDownModel name in ViewBag.DoctorList)
                        {
                            <option value="@name.DoctorID">@name.DoctorName</option>
                        }
                    </select>
                    <span asp-validation-for="DoctorID" class="text-danger small mt-1 d-block"></span>
                </div>

                @* Department Name Field *@
                <div class="col-12">
                    <label asp-for="DepartmentID" class="form-label fw-bold">Department Name</label>
                    <select class="form-select" asp-for="DepartmentID">
                        <option value="">-- Select Department --</option>
                        @foreach (Department_DropDown name in ViewBag.DepartmentList)
                        {
                            <option value="@name.DepartmentID">@name.DepartmentName</option>
                        }
                    </select>
                    <span asp-validation-for="DepartmentID" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 pt-4">
                <a asp-action="DoctorDepartmentList" asp-controller="DoctorDepartment" class="btn btn-outline-secondary d-flex align-items-center">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary d-flex align-items-center">
                    <i class="fas fa-save me-2"></i>Save Assignment
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}