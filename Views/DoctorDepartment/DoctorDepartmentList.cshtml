@model DataTable
@using System.Data

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div class="h2 text-primary fw-bold mb-2 mb-md-0">Doctor-Department Assignments</div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Hospital Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Doctor-Department List</li>
        </ol>
    </nav>
</div>

<div class="mb-4">
    @if (TempData["Successfully"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> <strong>Success!</strong> @TempData["Successfully"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Unsuccessfully"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> <strong>Error!</strong> @TempData["Unsuccessfully"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="card shadow-lg">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Assigned Departments</h5>
        <a href="#" class="btn btn-primary d-flex align-items-center shadow-sm">
            <i class="fas fa-plus me-2"></i> Assign Department
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover mt-2">
                <thead class="bg-light">
                    <tr>
                        <th scope="col" class="fw-bold">Doctor Name</th>
                        <th scope="col" class="fw-bold">Assigned Department(s)</th>
                        <th scope="col" class="text-center fw-bold">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in Model.Rows)
                    {
                        <tr class="align-middle">
                            <td>@row["Name"]</td>
                            <td><span class="badge rounded-pill bg-primary-subtle text-primary-emphasis">@row["DepartmentName"]</span></td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-controller="DoctorDepartment" asp-action="DoctorDepartmentUpdate" asp-route-DoctorDepartmentID="@row["DoctorDepartmentID"]" class="btn btn-sm btn-outline-warning" title="Edit">
                                        <i class="fas fa-pen-to-square"></i>
                                    </a>
                                    <a asp-controller="DoctorDepartment" asp-action="DoctorDepartmentDelete" asp-route-DoctorDepartmentID="@row["DoctorDepartmentID"]" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this assignment?');">
                                        <i class="fas fa-trash-can"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>