@model DataTable
@using System.Data

<div class="d-flex justify-content-between flex-wrap align-items-center mb-4">
    <div class="h2 text-primary fw-bold">Patient List</div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Hospital Management</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Patient</a></li>
            <li class="breadcrumb-item active" aria-current="page">Patient List</li>
        </ol>
    </nav>
</div>

<div class="mb-4">
    @if (TempData["Successfully"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> <strong>Success!</strong> @TempData["Successfully"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Unsuccessfully"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> <strong>Error!</strong> @TempData["Unsuccessfully"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="card shadow-lg">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Manage Patients</h5>
        <a asp-action="PatientAdd" asp-controller="Patient" class="btn btn-primary d-flex align-items-center shadow-sm">
            <i class="fas fa-plus me-2"></i> Add New Patient
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="bg-light">
                    <tr>
                        <th scope="col" class="fw-bold">Name</th>
                        <th scope="col" class="fw-bold">Gender</th>
                        <th scope="col" class="fw-bold">Email</th>
                        <th scope="col" class="fw-bold">Phone</th>
                        <th scope="col" class="fw-bold">City</th>
                        <th scope="col" class="fw-bold">State</th>
                        <th scope="col" class="text-center fw-bold">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in Model.Rows)
                    {
                        <tr class="align-middle">
                            <td>@row["PatientName"]</td>
                            <td>@row["Gender"]</td>
                            <td>@row["Email"]</td>
                            <td>@row["Phone"]</td>
                            <td>@row["City"]</td>
                            <td>@row["State"]</td>
                            <td class="text-center">
                                <div class="d-flex gap-2 justify-content-center">
                                    <a asp-controller="Patient" asp-action="PatientUpdate" asp-route-PatientID="@row["PatientID"]" class="btn btn-sm btn-outline-warning" title="Edit">
                                        <i class="fas fa-pen-to-square"></i>
                                    </a>
                                    <a asp-controller="Patient" asp-action="PatientDelete" asp-route-PatientID="@row["PatientID"]" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this patient?');">
                                        <i class="fas fa-trash-can"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>