@model DataTable
@using System.Data

<div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
    <div class="h2 text-primary fw-bold">User List</div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Hospital Management</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">User</a></li>
            <li class="breadcrumb-item active" aria-current="page">User List</li>
        </ol>
    </nav>
</div>

<div class="mb-4">
    @if (TempData["Successfully"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Successfully"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Unsuccessfully"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Unsuccessfully"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="card shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="card-title mb-0">Manage Users</h4>
        <button type="button" class="btn btn-primary d-flex align-items-center">
            <i class="fas fa-user-plus me-2"></i> Add User
        </button>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-hover mt-2" id="userTable">
            <thead class="bg-light">
                <tr>
                    <th scope="col" class="fw-bold">User ID</th>
                    <th scope="col" class="fw-bold">User Name</th>
                    <th scope="col" class="fw-bold">Email</th>
                    <th scope="col" class="fw-bold">Mobile No.</th>
                    <th scope="col" class="text-center fw-bold">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (DataRow row in Model.Rows)
                {
                    <tr class="align-middle">
                        <td>@row["UserID"]</td>
                        <td>@row["UserName"]</td>
                        <td>@row["Email"]</td>
                        <td>@row["MobileNo"]</td>
                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-controller="User" asp-action="UserUpdate" asp-route-UserID="@row["UserID"]" class="btn btn-sm btn-outline-warning" title="Edit">
                                    <i class="fas fa-pen-to-square"></i>
                                </a>
                                <a asp-controller="User" asp-action="UserDelete" asp-route-UserID="@row["UserID"]" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this user?');">
                                    <i class="fas fa-trash-can"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>