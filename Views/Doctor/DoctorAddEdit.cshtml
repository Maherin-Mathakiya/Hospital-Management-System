@model HMS.Models.DoctorModel
@using HMS.Models

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="h2 text-primary fw-bold mb-0">@(Model.DoctorID > 0 ? "Edit Doctor" : "Add New Doctor")</div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Hospital Management</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Doctor</a></li>
            <li class="breadcrumb-item active" aria-current="page">@(Model.DoctorID > 0 ? "Edit" : "Add")</li>
        </ol>
    </nav>
</div>

<div class="card shadow-lg p-4">
    <div class="card-body">
        <form method="post" asp-controller="Doctor" asp-action="DoctorSave">
            <input type="hidden" asp-for="DoctorID" />

            <fieldset class="border p-3 rounded mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold text-secondary">Personal Information</legend>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold">Name</label>
                        <input type="text" asp-for="Name" class="form-control" placeholder="Enter doctor's name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold">Email</label>
                        <input type="email" asp-for="Email" class="form-control" placeholder="Enter email address" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-bold">Phone</label>
                        <input type="tel" asp-for="Phone" class="form-control" placeholder="Enter phone number" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>
            </fieldset>

            <fieldset class="border p-3 rounded mb-4">
                <legend class="float-none w-auto px-2 fs-5 fw-bold text-secondary">Professional Information</legend>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Qualification" class="form-label fw-bold">Qualification</label>
                        <input type="text" asp-for="Qualification" class="form-control" placeholder="e.g., MBBS, MD" />
                        <span asp-validation-for="Qualification" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Specialization" class="form-label fw-bold">Specialization</label>
                        <input type="text" asp-for="Specialization" class="form-control" placeholder="e.g., Cardiology, Neurology" />
                        <span asp-validation-for="Specialization" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="UserID" class="form-label fw-bold">User Name</label>
                        <select asp-for="UserID" class="form-select">
                            <option value="">Select User Name</option>
                            @foreach (DoctorDropDownModel name in ViewBag.UserList)
                            {
                                <option value="@name.UserID">@name.UserName</option>
                            }
                        </select>
                        <span asp-validation-for="UserID" class="text-danger small"></span>
                    </div>
                </div>
            </fieldset>

            <div class="d-flex justify-content-end gap-2 pt-2">
                <a asp-action="DoctorList" asp-controller="Doctor" class="btn btn-outline-secondary d-flex align-items-center">
                    <i class="fas fa-times me-2"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary d-flex align-items-center">
                    @if (Model.DoctorID > 0)
                    {
                        <span><i class="fas fa-save me-2"></i> Update Doctor</span>
                    }
                    else
                    {
                        <span><i class="fas fa-user-md me-2"></i> Save Doctor</span>
                    }
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}