@model DataTable
@using System.Data

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div class="h2 text-primary fw-bold mb-2 mb-md-0">Doctor List</div>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Hospital Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Doctor List</li>
        </ol>
    </nav>
</div>

<div class="mb-4">
    @if (TempData["Successfully"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> <strong>Success!</strong> @TempData["Successfully"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Unsuccessfully"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> <strong>Error!</strong> @TempData["Unsuccessfully"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="card shadow-lg">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Manage Doctors</h5>
        <a href="#" class="btn btn-primary d-flex align-items-center shadow-sm">
            <i class="fas fa-plus me-2"></i> Add New Doctor
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="bg-light">
                    <tr>
                        <th scope="col" class="fw-bold text-nowrap">Doctor Name</th>
                        <th scope="col" class="fw-bold">Phone</th>
                        <th scope="col" class="fw-bold">Email</th>
                        <th scope="col" class="fw-bold text-nowrap">Qualification</th>
                        <th scope="col" class="fw-bold text-nowrap">Specialization</th>
                        <th scope="col" class="text-center fw-bold">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in Model.Rows)
                    {
                        <tr class="align-middle">
                            <td>@row["Name"]</td>
                            <td>@row["Phone"]</td>
                            <td>@row["Email"]</td>
                            <td>@row["Qualification"]</td>
                            <td><span class="badge rounded-pill bg-primary-subtle text-primary-emphasis">@row["Specialization"]</span></td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-controller="Doctor" asp-action="DoctorUpdate" asp-route-DoctorID="@row["DoctorID"]" class="btn btn-sm btn-outline-warning d-flex align-items-center" title="Edit">
                                        <i class="fas fa-pen-to-square"></i>
                                    </a>
                                    <a asp-controller="Doctor" asp-action="DoctorDelete" asp-route-DoctorID="@row["DoctorID"]" class="btn btn-sm btn-outline-danger d-flex align-items-center" title="Delete">
                                        <i class="fas fa-trash-can"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>